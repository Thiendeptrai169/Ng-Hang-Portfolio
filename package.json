{
  "name": "ng-hang-game-artist-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && vite --host 127.0.0.1",
    "build:css": "tailwindcss -i ./css/input.css -o ./css/output.css --minify",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/output.css --watch",
    "build": "npm run build:css && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "capture": "node scripts/capture.mjs",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "playwright-core": "^1.61.0",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.16"
  }
}
